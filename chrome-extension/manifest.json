{
  "manifest_version": 3,
  "name": "SafePay Fraud Scanner",
  "description": "AI-powered fraud detection for UPI payments, SMS scams, QR codes, and suspicious URLs.",
  "version": "2.0.0",
  "action": {
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "tabs",
    "notifications",
    "contextMenus",
    "alarms",
    "sidePanel"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://127.0.0.1:8000/*",
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["jsQR.min.js", "content.js"],
      "run_at": "document_idle"
    }
  ]
}
