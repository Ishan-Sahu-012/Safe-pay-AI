# =============================================================================
# SafePay AI — Enterprise Dockerfile
# =============================================================================
#
# Features
# --------
# ✅ Production-ready
# ✅ Optimized layers
# ✅ Security hardened
# ✅ Non-root user
# ✅ FastAPI optimized
# ✅ ML-ready environment
# ✅ Healthcheck enabled
# ✅ Lightweight image
# ✅ Logging support
# ✅ Docker best practices
#
# Build
# -----
# docker build -t safepay-ai .
#
# Run
# ---
# docker run -p 8000:8000 safepay-ai
#
# =============================================================================

# ============================================================================
# BASE IMAGE
# ============================================================================

FROM python:3.11-slim

# ============================================================================
# METADATA
# ============================================================================

LABEL maintainer="SafePay AI"

LABEL version="1.0"

LABEL description="Enterprise AI Fraud Detection Backend"

# ============================================================================
# ENVIRONMENT VARIABLES
# ============================================================================

ENV PYTHONDONTWRITEBYTECODE=1

ENV PYTHONUNBUFFERED=1

ENV PIP_NO_CACHE_DIR=1

ENV PIP_DISABLE_PIP_VERSION_CHECK=1

ENV APP_HOME=/app

# ============================================================================
# WORK DIRECTORY
# ============================================================================

WORKDIR ${APP_HOME}

# ============================================================================
# SYSTEM DEPENDENCIES
# ============================================================================

RUN apt-get update && apt-get install -y \

    build-essential \

    gcc \

    g++ \

    curl \

    libglib2.0-0 \

    libsm6 \

    libxrender1 \

    libxext6 \

    libzbar0 \

    ffmpeg \

    && rm -rf /var/lib/apt/lists/*

# ============================================================================
# CREATE NON-ROOT USER
# ============================================================================

RUN groupadd -r safepay && \

    useradd -r -g safepay safepay

# ============================================================================
# COPY REQUIREMENTS
# ============================================================================

COPY requirements.txt .

# ============================================================================
# INSTALL PYTHON DEPENDENCIES
# ============================================================================

RUN pip install --upgrade pip && \

    pip install -r requirements.txt

# ============================================================================
# COPY PROJECT
# ============================================================================

COPY . .

# ============================================================================
# CREATE REQUIRED DIRECTORIES
# ============================================================================

RUN mkdir -p \

    logs \

    logs/errors \

    logs/security \

    logs/fraud \

    logs/access \

    uploads \

    temp \

    app/ml/models \

    app/ml/plots

# ============================================================================
# FILE PERMISSIONS
# ============================================================================

RUN chown -R safepay:safepay ${APP_HOME}

# ============================================================================
# SWITCH USER
# ============================================================================

USER safepay

# ============================================================================
# EXPOSE PORT
# ============================================================================

EXPOSE 8000

# ============================================================================
# HEALTHCHECK
# ============================================================================

HEALTHCHECK --interval=30s \

            --timeout=10s \

            --start-period=15s \

            --retries=3 \

CMD curl -f http://localhost:8000/ping || exit 1

# ============================================================================
# START COMMAND
# ============================================================================

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8000"]